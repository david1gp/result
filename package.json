{
  "name": "@adaptive-ds/result",
  "version": "0.5.0",
  "scripts": {
    "build": "rm -rf ./dist && bun tsc -p ./tsconfig.lib.json",
    "test": "bun test",
    "test:w": "bun test --watch",
    "release": "bash ./ops/release.sh",
    "update": "bun update",
    "update:commit": "bun update && git add package.json && bun run tsc && git commit -m \"chore(deps): update dependencies\" && git push",
    "clean": "rm -rf ./dist",
    "reset": "rm -rf ./node_modules"
  },
  "peerDependencies": {
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120,
    "trailingComma": "all"
  },
  "type": "module",
  "main": "dist/index.js",
  "private": false,
  "license": "MIT",
  "description": "A simple, type-safe Result type for TypeScript. Handle errors gracefully without try-catch soup.",
  "keywords": [
    "typescript",
    "result",
    "error-handling",
    "either",
    "functional-programming"
  ],
  "homepage": "https://github.com/david1gp/result",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david1gp/result.git"
  },
  "bugs": {
    "url": "https://github.com/david1gp/result/issues"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ]
}
